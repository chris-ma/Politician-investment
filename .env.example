# ── Database ──────────────────────────────────────────────────────────────────
# Vercel Postgres (Neon) provides two URLs in the project dashboard:
#   POSTGRES_URL          → goes through pgBouncer (use this for the web app)
#   POSTGRES_URL_NON_POOLING → direct connection (use this for scripts/migrations)
#
# For other providers (Supabase, Railway Postgres, etc.) use their connection
# string with ?sslmode=require appended where required.
#
# Local development:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/politicians_db

# ── Parliament of Australia register URLs ─────────────────────────────────────
APH_MEMBERS_URL=https://www.aph.gov.au/Parliamentary_Business/Disclosures/Register_of_Members_Interests
APH_SENATORS_URL=https://www.aph.gov.au/Parliamentary_Business/Disclosures/Register_of_Senators_Interests
APH_BASE_URL=https://www.aph.gov.au

# ── Admin ─────────────────────────────────────────────────────────────────────
# Protects the one-time seed endpoint: GET /api/admin/seed?token=<value>
# Use any long random string, e.g.: openssl rand -hex 32
ADMIN_SECRET=change-me-to-a-long-random-string

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
